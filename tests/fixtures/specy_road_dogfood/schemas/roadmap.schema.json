{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://specy-road.local/schemas/roadmap.schema.json",
  "title": "specy-road roadmap",
  "type": "object",
  "required": ["version", "nodes"],
  "additionalProperties": false,
  "properties": {
    "version": { "type": "integer", "const": 1 },
    "nodes": {
      "type": "array",
      "items": { "$ref": "#/$defs/node" }
    }
  },
  "$defs": {
    "node": {
      "type": "object",
      "required": ["id", "node_key", "type", "title"],
      "additionalProperties": false,
      "properties": {
        "node_key": {
          "type": "string",
          "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$",
          "description": "Stable UUID for dependencies and registry; display id may be renumbered."
        },
        "id": {
          "type": "string",
          "pattern": "^M[0-9]+(\\.[0-9]+)*$",
          "description": "Hierarchical display id (e.g. M1.2); may change when outline is reorganized."
        },
        "parent_id": {
          "type": ["string", "null"],
          "pattern": "^M[0-9]+(\\.[0-9]+)*$"
        },
        "type": {
          "type": "string",
          "enum": ["vision", "phase", "milestone", "task"]
        },
        "title": { "type": "string", "minLength": 1 },
        "codename": {
          "type": ["string", "null"],
          "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
        },
        "execution_milestone": {
          "type": ["string", "null"],
          "enum": [null, "Human-led", "Agentic-led", "Mixed"]
        },
        "execution_subtask": {
          "type": ["string", "null"],
          "enum": [null, "human", "agentic", "human-gate"]
        },
        "status": {
          "type": "string",
          "enum": ["Not Started", "In Progress", "Complete", "Blocked"]
        },
        "touch_zones": {
          "type": "array",
          "items": { "type": "string" }
        },
        "dependencies": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
          },
          "description": "Depends-on node_key values (stable UUIDs)."
        },
        "parallel_tracks": { "type": ["integer", "null"], "minimum": 1 },
        "sibling_order": {
          "type": "integer",
          "description": "Sort order among nodes with the same parent_id (lower first). Defaults to 0 when omitted."
        },
        "notes": { "type": "string" },
        "planning_dir": {
          "type": ["string", "null"],
          "description": "Repo-relative path to a single feature sheet under planning/, e.g. planning/M1.1_slug_<node_key>.md; required for types vision, phase, milestone, and task (enforced in validate_roadmap.py). See planning/README.md."
        },
        "goal": {
          "type": "string",
          "minLength": 1,
          "description": "Concise statement of what this node achieves when complete."
        },
        "acceptance": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1,
          "description": "Observable acceptance criteria — what must be true for this node to be considered done."
        },
        "risks": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "description": "Known risks or blockers to surface for planning."
        },
        "decision": {
          "type": "object",
          "description": "Architecture or policy decision block for milestones with a pending or resolved fork.",
          "required": ["status"],
          "additionalProperties": false,
          "properties": {
            "status": {
              "type": "string",
              "enum": ["pending", "decided"]
            },
            "decided_date": {
              "type": "string",
              "description": "ISO 8601 date when the decision was made."
            },
            "adr_ref": {
              "type": "string",
              "description": "Path or identifier of the ADR capturing the decision (e.g. docs/adr/ADR-001.md)."
            }
          }
        },
        "agentic_checklist": {
          "type": ["object", "null"],
          "additionalProperties": false,
          "description": "Required when execution_subtask is agentic. Five required elements (completeness standard) plus two optional signals.",
          "properties": {
            "artifact_action": { "type": "string", "minLength": 1 },
            "contract_citation": {
              "type": "string",
              "minLength": 1,
              "description": "Which contract doc, section, or entity to conform to."
            },
            "interface_contract": { "type": "string", "minLength": 1 },
            "constraints_note": { "type": "string", "minLength": 1 },
            "dependency_note": { "type": "string", "minLength": 1 },
            "success_signal": {
              "type": "string",
              "minLength": 1,
              "description": "Observable test or behavior that confirms the task is done correctly."
            },
            "forbidden_patterns": {
              "type": "string",
              "minLength": 1,
              "description": "Patterns explicitly prohibited in this task (e.g. 'do not call live service — use stub')."
            }
          },
          "required": [
            "artifact_action",
            "contract_citation",
            "interface_contract",
            "constraints_note",
            "dependency_note"
          ]
        }
      }
    }
  }
}
